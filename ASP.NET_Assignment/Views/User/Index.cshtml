@model IEnumerable<UserToReturnDto>
@{
    ViewData["Title"] = "Users";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 mb-1">User Management</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Users</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white border-0 py-3">
            <form class="row g-3" method="get">
                <div class="col-md-10">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-search"></i>
                        </span>
                        <input class="form-control border-start-0"
                               placeholder="Search by name, username, or email..."
                               id="txt"
                               name="SearchText"
                               value="@ViewBag.SearchText">
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success btn-lg w-100">
                        <i class="bi bi-search me-2"></i>Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Count() > 0)
    {
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="bi bi-people-fill me-2"></i>All Users
                    <span class="badge bg-light text-primary ms-2">@Model.Count()</span>
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table id="table" class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Image</th>
                                <th>ID</th>
                                <th>Username</th>
                                <th>First Name</th>
                                <th>Last Name</th>
                                <th>Email</th>
                                <th>Roles</th>
                                <th></th>
                                <th>Details</th>
                                <th>Delete</th>
                            </tr>
                        </thead>
                        <tbody id="table-body">
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <img src="~/Files/Images/@item.Image"
                                             class="user-image rounded-circle"
                                             alt="@item.UserName"
                                             onerror="this.src='~/Files/Images/default-avatar.png'" />
                                    </td>
                                    <td class="fw-semibold text-muted">
                                        @if (item.Id == ViewBag.LoggedInUser)
                                        {
                                            <i class="bi bi-person-fill-check text-success ms-1"
                                               title="Current User"
                                               style="font-size: 1rem;"></i>
                                        }
                                        #@item.Id
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <span class="fw-semibold">@item.UserName</span>
                                        </div>
                                    </td>
                                    <td>@item.FirstName</td>
                                    <td>@item.LastName</td>
                                    <td>
                                        <a href="mailto:@item.Email" class="text-decoration-none">
                                            <i class="bi bi-envelope me-1"></i>@item.Email
                                        </a>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var role in item.Roles)
                                            {
                                                <span class="badge bg-primary">@role</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <partial name="_DetailsButtonPartialViews" model="@item.Id" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-5">
                <i class="bi bi-people" style="font-size: 4rem; color: #cbd5e0;"></i>
                <h4 class="mt-3 mb-2">No Users Found</h4>
                <p class="text-muted mb-4">
                    @if (!string.IsNullOrEmpty(ViewBag.SearchText as string))
                    {
                        <span>No users match your search criteria. Try a different search term.</span>
                    }
                    else
                    {
                        <span>There are no users in the system yet. Start by adding a new user.</span>
                    }
                </p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>Add First User
                </a>
            </div>
        </div>
    }
</div>

<style>
    .card {
        border-radius: 0.5rem;
    }

    .card-header {
        border-radius: 0.5rem 0.5rem 0 0 !important;
        padding: 1rem 1.25rem;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
    }

    .input-group-text {
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
    }

    .form-control {
        border: 1px solid #dee2e6;
    }

        .form-control:focus {
            border-color: #86b7fe;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        }

    /* User Image Styling */
    .user-image {
        width: 45px;
        height: 45px;
        object-fit: cover;
        border: 2px solid #e9ecef;
        transition: transform 0.2s ease;
    }

        .user-image:hover {
            transform: scale(1.1);
            border-color: #0d6efd;
        }

    .user-avatar {
        font-size: 1.5rem;
        color: #6c757d;
    }

    .table > :not(caption) > * > * {
        padding: 1rem 0.75rem;
        vertical-align: middle;
    }

    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
    }

    .badge {
        padding: 0.375rem 0.75rem;
        font-weight: 500;
        font-size: 0.75rem;
    }

    .btn-group-sm > .btn, .btn-sm {
        padding: 0.25rem 0.75rem;
        font-size: 0.875rem;
    }

    @@media (max-width: 767.98px) {
        .d-flex.justify-content-between

    {
        flex-direction: column;
        gap: 1rem;
    }

    .d-flex.justify-content-between .btn {
        width: 100%;
    }

    .table {
        font-size: 0.875rem;
    }

    .user-image {
        width: 35px;
        height: 35px;
    }

    }
</style>