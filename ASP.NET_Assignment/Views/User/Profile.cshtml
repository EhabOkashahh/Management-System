@model UserToReturnDto
@{
    ViewData["Title"] = "My Profile";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 mb-1">My Profile</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Home</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Profile</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-person-circle me-2"></i>Profile Picture
                    </h5>
                </div>
                <div class="card-body text-center p-4">
                    <div class="profile-photo-container mb-3">
                        <img id="profilePhoto"
                             src="~/Files/Images/@Model.Image"
                             alt="Profile Photo"
                             onerror="this.src='/images/default-avatar.png'">
                    </div>
                    <p class="text-muted small mb-0">
                        <i class="bi bi-info-circle me-1"></i>
                        Upload a new photo to update your profile picture
                    </p>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0">
                        <i class="bi bi-shield-check me-2"></i>Account Status
                    </h6>
                </div>
                <div class="card-body">
                    <div class="status-item mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Phone Verification</span>
                            @if (Model.IsConfirmed)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle me-1"></i>Verified
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-exclamation-triangle me-1"></i>Pending
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-person-badge me-2"></i>Profile Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Profile" enctype="multipart/form-data" id="profileForm">
                        <partial name="PartialViews/_FormView" />

                        <div class="mb-4">
                            <label asp-for="PhoneNumber" class="form-label fw-bold">
                            </label>
                            <input asp-for="PhoneNumber" class="form-control form-control-lg" placeholder="Enter your phone number">
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>

                            @if (Model.PhoneNumber == null)
                            {
                                <div class="alert alert-warning mt-2 d-flex align-items-start" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill me-2 mt-1"></i>
                                    <div>
                                        <small>
                                            <strong>Phone number required:</strong> Please add your phone number to enable verification.
                                        </small>
                                    </div>
                                </div>
                                <button class="btn btn-warning" disabled>
                                    <i class="bi bi-telephone me-2"></i>Confirm Phone Number
                                </button>
                            }
                            else
                            {
                                @if (!Model.IsConfirmed)
                                {
                                    <div class="alert alert-info mt-2 d-flex align-items-start" role="alert">
                                        <i class="bi bi-info-circle-fill me-2 mt-1"></i>
                                        <div>
                                            <small>
                                                Please make sure your phone is nearby. Clicking the button below will send you an SMS verification code.
                                            </small>
                                        </div>
                                    </div>
                                    <a asp-action="ConfirmPhoneNumber" asp-route-Id="@Model.Id" class="btn btn-warning">
                                        <i class="bi bi-telephone me-2"></i>Send Verification Code
                                    </a>
                                    @if (ViewData["PhoneNumber"] != null)
                                    {
                                        <div class="text-danger small mt-2">
                                            <i class="bi bi-exclamation-circle me-1"></i>@ViewData["PhoneNumber"]
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="alert alert-success mt-2 d-flex align-items-center" role="alert">
                                        <i class="bi bi-check-circle-fill me-2"></i>
                                        <span>Your phone number is verified</span>
                                    </div>
                                }
                            }
                        </div>

                        <div class="mb-4">
                            <label asp-for="ImageLink" class="form-label fw-bold">
                                <i class="bi bi-image me-1"></i>Profile Picture
                            </label>
                            <input asp-for="ImageLink" class="form-control form-control-lg" type="file" accept="image/*">
                            <span asp-validation-for="ImageLink" class="text-danger small"></span>
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>
                                Accepted formats: JPG, PNG, GIF (max 5MB)
                            </div>
                        </div>

                        <input asp-for="Image" hidden />

                        <div class="alert alert-info d-flex align-items-start" role="alert">
                            <i class="bi bi-info-circle-fill me-2 mt-1"></i>
                            <div>
                                <small>
                                    <strong>Note:</strong> Changes will be saved to your profile immediately after clicking "Save Changes".
                                </small>
                            </div>
                        </div>

                        <div class="d-flex gap-2 pt-3 border-top">
                            <button type="submit" class="btn btn-primary btn-lg" id="saveBtn">
                                <i class="bi bi-check-circle me-2"></i>Save Changes
                            </button>
                            <button type="reset" class="btn btn-outline-secondary btn-lg" id="resetBtn">
                                <i class="bi bi-arrow-counterclockwise me-2"></i>Reset
                            </button>
                            <a class="btn btn-outline-danger btn-lg ms-auto" asp-action="Index" asp-controller="Home">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border-radius: 0.5rem;
    }

    .card-header {
        border-radius: 0.5rem 0.5rem 0 0 !important;
        padding: 1rem 1.25rem;
    }

    .profile-photo-container {
        width: 200px;
        height: 200px;
        margin: 0 auto;
        border-radius: 50%;
        overflow: hidden;
        border: 4px solid #e9ecef;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .profile-photo-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .status-item {
        padding: 0.75rem;
        background: #f8f9fa;
        border-radius: 0.375rem;
    }

    .badge {
        padding: 0.5rem 0.75rem;
        font-weight: 500;
        font-size: 0.875rem;
    }

    .btn-lg {
        padding: 0.625rem 1.25rem;
        font-size: 1rem;
    }

    .gap-2 {
        gap: 0.5rem !important;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
    }

    .btn.loading {
        position: relative;
        color: transparent;
    }

        .btn.loading::after {
            content: "";
            position: absolute;
            width: 16px;
            height: 16px;
            top: 50%;
            left: 50%;
            margin-left: -8px;
            margin-top: -8px;
            border: 2px solid currentColor;
            border-radius: 50%;
            border-top-color: transparent;
            animation: spinner 0.6s linear infinite;
        }

    @@keyframes spinner {
        to

    {
        transform: rotate(360deg);
    }

    }

    .alert-info {
        background-color: #e7f3ff;
        border-color: #b3d9ff;
        color: #004085;
    }

    @@media (max-width: 992px) {
        .col-lg-4

    {
        margin-bottom: 1rem;
    }

    }

    @@media (max-width: 768px) {
        .d-flex.gap-2

    {
        flex-direction: column;
    }

    .d-flex.gap-2 .btn {
        width: 100%;
    }

    .d-flex.gap-2 .ms-auto {
        margin-left: 0 !important;
    }

    .profile-photo-container {
        width: 150px;
        height: 150px;
    }

    }
</style>

@section ValidationSection {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#profileForm').on('submit', function(e) {
                if ($(this).valid()) {
                    const saveBtn = $('#saveBtn');
                    saveBtn.addClass('loading').prop('disabled', true);
                }
            });

            $('#resetBtn').on('click', function(e) {
                e.preventDefault();
                if (confirm('Are you sure you want to reset all changes? Any unsaved modifications will be lost.')) {
                    $('#profileForm')[0].reset();
                    $('#profileForm').validate().resetForm();
                    $('.form-control, .form-select').removeClass('is-valid is-invalid');
                    $('#profilePhoto').attr('src', '~/Files/Images/@Model.Image');
                }
            });

            $('input[type="file"]').on('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    const validTypes = ['image/jpeg', 'image/png', 'image/gif'];
                    if (!validTypes.includes(file.type)) {
                        alert('Please upload a valid image file (JPG, PNG, or GIF)');
                        $(this).val('');
                        return;
                    }

                    if (file.size > 5 * 1024 * 1024) {
                        alert('File size must be less than 5MB');
                        $(this).val('');
                        return;
                    }

                    const reader = new FileReader();
                    reader.onload = function(e) {
                        $('#profilePhoto').attr('src', e.target.result);
                    };
                    reader.readAsDataURL(file);
                }
            });

            let formChanged = false;
            $('#profileForm :input').not('[type="hidden"]').on('change', function() {
                formChanged = true;
            });

            $('a[href]').not('[href^="#"]').on('click', function(e) {
                if (formChanged) {
                    if (!confirm('You have unsaved changes. Are you sure you want to leave?')) {
                        e.preventDefault();
                    }
                }
            });

            $('#profileForm').on('submit', function() {
                formChanged = false;
            });

            $.validator.setDefaults({
                errorElement: 'span',
                errorClass: 'invalid-feedback',
                highlight: function(element) {
                    $(element).addClass('is-invalid').removeClass('is-valid');
                },
                unhighlight: function(element) {
                    $(element).removeClass('is-invalid').addClass('is-valid');
                }
            });

            setTimeout(function() {
                $('.alert-danger').fadeOut('slow');
            }, 7000);

            $('.form-control, .form-select').on('focus', function() {
                $(this).parent().addClass('field-focused');
            }).on('blur', function() {
                $(this).parent().removeClass('field-focused');
            });
        });
    </script>
}