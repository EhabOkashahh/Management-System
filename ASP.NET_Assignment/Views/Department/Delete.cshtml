@model Department
@{
    ViewData["Title"] = "Delete Department";
}

<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Department">Departments</a></li>
                <li class="breadcrumb-item active" aria-current="page">Delete Confirmation</li>
            </ol>
        </nav>
    </div>

    <!-- Delete Confirmation Card -->
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card border-danger shadow-lg">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Confirmation
                    </h5>
                </div>
                <div class="card-body p-4">
                    <!-- Warning Icon -->
                    <div class="text-center mb-4">
                        <div class="warning-icon-circle mx-auto">
                            <i class="bi bi-trash3-fill"></i>
                        </div>
                    </div>

                    <!-- Warning Message -->
                    <div class="text-center mb-4">
                        <h4 class="fw-bold text-danger mb-3">Are You Sure?</h4>
                        <p class="text-muted mb-2">
                            You are about to permanently delete this department. This action <strong>cannot be undone</strong>.
                        </p>
                    </div>

                    <!-- Department Details to Delete -->
                    @if (Model != null)
                    {
                        <div class="alert alert-light border mb-4">
                            <h6 class="text-muted mb-3">
                                <i class="bi bi-info-circle me-2"></i>Department Details
                            </h6>
                            <div class="row g-3">
                                <div class="col-6">
                                    <small class="text-muted d-block">Department Code</small>
                                    <strong>@Model.Code</strong>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">Department Name</small>
                                    <strong>@Model.Name</strong>
                                </div>
                                <div class="col-12">
                                    <small class="text-muted d-block">Created On</small>
                                    <strong>@Model.DateOfCreation.ToString("MMMM dd, yyyy")</strong>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Warning List -->
                    <div class="alert alert-warning border-warning" role="alert">
                        <h6 class="alert-heading">
                            <i class="bi bi-exclamation-circle me-2"></i>Please Note:
                        </h6>
                        <ul class="mb-0 ps-3">
                            <li>This action is <strong>permanent and irreversible</strong></li>
                            <li>All associated data will be removed</li>
                            <li>Employees linked to this department may be affected</li>
                            <li>Historical records will be lost</li>
                        </ul>
                    </div>

                    <!-- Confirmation Checkbox -->
                    <div class="form-check mb-4">
                        <input class="form-check-input" type="checkbox" id="confirmCheck">
                        <label class="form-check-label" for="confirmCheck">
                            I understand that this action cannot be undone
                        </label>
                    </div>

                    <!-- Action Buttons -->
                    <form asp-action="Delete" method="post" id="deleteForm">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg" id="deleteBtn" disabled>
                                <i class="bi bi-trash3 me-2"></i>Yes, Delete Permanently
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-x-circle me-2"></i>No, Cancel & Go Back
                            </a>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light text-center">
                    <small class="text-muted">
                        <i class="bi bi-shield-check me-1"></i>
                        This is a safety confirmation to prevent accidental deletions
                    </small>
                </div>
            </div>

            <!-- Additional Help Card -->
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body">
                    <h6 class="mb-2">
                        <i class="bi bi-question-circle me-2"></i>Need an Alternative?
                    </h6>
                    <p class="mb-2 small text-muted">
                        Instead of deleting, consider archiving or deactivating this department to preserve historical data.
                    </p>
                    <a href="#" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-archive me-1"></i>Learn About Archiving
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Warning Icon Circle */
    .warning-icon-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(220, 53, 69, 0.3);
        animation: pulse 2s infinite;
    }

        .warning-icon-circle i {
            font-size: 2.5rem;
            color: white;
        }

    @@keyframes pulse {
        0%, 100%

    {
        box-shadow: 0 4px 15px rgba(220, 53, 69, 0.3);
    }

    50% {
        box-shadow: 0 4px 25px rgba(220, 53, 69, 0.5);
    }

    }

    /* Card Styles */
    .card {
        border-radius: 0.5rem;
    }

    .card-header {
        border-radius: 0.5rem 0.5rem 0 0 !important;
        padding: 1rem 1.25rem;
    }

    .border-danger {
        border-width: 2px !important;
    }

    /* Button Styles */
    .btn-lg {
        padding: 0.75rem 1.5rem;
        font-weight: 600;
    }

    #deleteBtn:disabled {
        cursor: not-allowed;
        opacity: 0.6;
    }

    #deleteBtn:not(:disabled):hover {
        background-color: #c82333;
        border-color: #bd2130;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(220, 53, 69, 0.3);
    }

    .btn {
        transition: all 0.2s ease;
    }

    /* Alert Styles */
    .alert {
        border-radius: 0.375rem;
    }

        .alert ul {
            margin-bottom: 0;
        }

            .alert ul li {
                margin-bottom: 0.25rem;
            }

                .alert ul li:last-child {
                    margin-bottom: 0;
                }

    /* Checkbox Styles */
    .form-check-input {
        width: 1.25em;
        height: 1.25em;
        cursor: pointer;
    }

        .form-check-input:checked {
            background-color: #dc3545;
            border-color: #dc3545;
        }

    .form-check-label {
        cursor: pointer;
        user-select: none;
    }

    /* Breadcrumb */
    .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
    }

    /* Gap utility */
    .gap-2 {
        gap: 0.5rem !important;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .warning-icon-circle

    {
        width: 60px;
        height: 60px;
    }

    .warning-icon-circle i {
        font-size: 2rem;
    }

    h4 {
        font-size: 1.25rem;
    }

    }

    /* Loading State for Submit Button */
    .btn.loading {
        position: relative;
        color: transparent;
    }

        .btn.loading::after {
            content: "";
            position: absolute;
            width: 20px;
            height: 20px;
            top: 50%;
            left: 50%;
            margin-left: -10px;
            margin-top: -10px;
            border: 3px solid #ffffff;
            border-radius: 50%;
            border-top-color: transparent;
            animation: spinner 0.6s linear infinite;
        }

    @@keyframes spinner {
        to

    {
        transform: rotate(360deg);
    }

    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const confirmCheck = document.getElementById('confirmCheck');
        const deleteBtn = document.getElementById('deleteBtn');
        const deleteForm = document.getElementById('deleteForm');

        // Enable/disable delete button based on checkbox
        confirmCheck.addEventListener('change', function() {
            deleteBtn.disabled = !this.checked;
        });

        // Add loading state and confirmation on form submit
        deleteForm.addEventListener('submit', function(e) {
            e.preventDefault();

            // Double confirmation
            const confirmed = confirm(
                '⚠️ FINAL WARNING ⚠️\n\n' +
                'This department will be PERMANENTLY deleted.\n\n' +
                'Are you absolutely sure you want to proceed?'
            );

            if (confirmed) {
                // Add loading state
                deleteBtn.classList.add('loading');
                deleteBtn.disabled = true;

                // Submit the form
                this.submit();
            }
        });

        // Prevent accidental navigation
        window.addEventListener('beforeunload', function(e) {
            if (confirmCheck.checked) {
                e.preventDefault();
                e.returnValue = '';
            }
        });
    });
</script>