@model CreateEmployeeDTO
@{
    ViewData["Title"] = "Create Employee";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 mb-1">Create New Employee</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Employees">Employees</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Create</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-person-plus-fill me-2"></i>Employee Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create"
                          enctype="multipart/form-data"
                          id="createEmployeeForm">

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <strong>Please correct the following errors:</strong>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>

                        <partial name="PartialViews/_EmployeeFormsViews" />

                        <div class="d-flex gap-2 pt-3 border-top">
                            <button type="submit" class="btn btn-success btn-lg" id="submitBtn">
                                <i class="bi bi-check-circle me-2"></i>Create Employee
                            </button>
                            <button type="reset" class="btn btn-outline-secondary btn-lg" id="resetBtn">
                                <i class="bi bi-arrow-counterclockwise me-2"></i>Reset Form
                            </button>
                            <a class="btn btn-outline-danger btn-lg ms-auto" asp-action="Index">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0">
                        <i class="bi bi-image me-2"></i>Photo Preview
                    </h6>
                </div>
                <div class="card-body text-center">
                    <div class="photo-preview-container mb-3">
                        <img id="photoPreview"
                             src="/images/default-avatar.png"
                             alt="Photo Preview">
                    </div>
                    <p class="text-muted small mb-0">
                        <i class="bi bi-info-circle me-1"></i>
                        Upload a photo to see preview
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border-radius: 0.5rem;
    }

    .card-header {
        border-radius: 0.5rem 0.5rem 0 0 !important;
        padding: 1rem 1.25rem;
    }

    .photo-preview-container {
        width: 200px;
        height: 200px;
        margin: 0 auto;
        border-radius: 50%;
        overflow: hidden;
        border: 4px solid #e9ecef;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .photo-preview-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .btn-lg {
        padding: 0.625rem 1.25rem;
        font-size: 1rem;
    }

    .gap-2 {
        gap: 0.5rem !important;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
    }

    .btn.loading {
        position: relative;
        color: transparent;
    }

        .btn.loading::after {
            content: "";
            position: absolute;
            width: 16px;
            height: 16px;
            top: 50%;
            left: 50%;
            margin-left: -8px;
            margin-top: -8px;
            border: 2px solid currentColor;
            border-radius: 50%;
            border-top-color: transparent;
            animation: spinner 0.6s linear infinite;
        }

    @@keyframes spinner {
        to

    {
        transform: rotate(360deg);
    }

    }

    .alert-info {
        background-color: #e7f3ff;
        border-color: #b3d9ff;
        color: #004085;
    }

    @@media (max-width: 992px) {
        .col-lg-4

    {
        margin-top: 1rem;
    }

    }

    @@media (max-width: 768px) {
        .d-flex.gap-2

    {
        flex-direction: column;
    }

    .d-flex.gap-2 .btn {
        width: 100%;
    }

    .d-flex.gap-2 .ms-auto {
        margin-left: 0 !important;
    }

    .photo-preview-container {
        width: 150px;
        height: 150px;
    }

    }
</style>

@section ValidationSection {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#createEmployeeForm').on('submit', function(e) {
                if ($(this).valid()) {
                    const submitBtn = $('#submitBtn');
                    submitBtn.addClass('loading').prop('disabled', true);
                }
            });

            $('#resetBtn').on('click', function(e) {
                e.preventDefault();
                if (confirm('Are you sure you want to reset the form? All entered information will be lost.')) {
                    $('#createEmployeeForm')[0].reset();
                    $('#createEmployeeForm').validate().resetForm();
                    $('.form-control, .form-select').removeClass('is-valid is-invalid');
                    $('#photoPreview').attr('src', '/images/default-avatar.png');
                }
            });

            $('input[type="file"]').on('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    const validTypes = ['image/jpeg', 'image/png', 'image/gif'];
                    if (!validTypes.includes(file.type)) {
                        alert('Please upload a valid image file (JPG, PNG, or GIF)');
                        $(this).val('');
                        return;
                    }

                    if (file.size > 5 * 1024 * 1024) {
                        alert('File size must be less than 5MB');
                        $(this).val('');
                        return;
                    }

                    const reader = new FileReader();
                    reader.onload = function(e) {
                        $('#photoPreview').attr('src', e.target.result);
                    };
                    reader.readAsDataURL(file);
                }
            });

            let formChanged = false;
            $('#createEmployeeForm :input').not('[type="hidden"]').on('change', function() {
                formChanged = true;
            });

            $('a[href]').not('[href^="#"]').on('click', function(e) {
                if (formChanged) {
                    if (!confirm('You have unsaved changes. Are you sure you want to leave?')) {
                        e.preventDefault();
                    }
                }
            });

            $('#createEmployeeForm').on('submit', function() {
                formChanged = false;
            });

            $.validator.setDefaults({
                errorElement: 'span',
                errorClass: 'invalid-feedback',
                highlight: function(element) {
                    $(element).addClass('is-invalid').removeClass('is-valid');
                },
                unhighlight: function(element) {
                    $(element).removeClass('is-invalid').addClass('is-valid');
                }
            });

            setTimeout(function() {
                $('.alert-danger').fadeOut('slow');
            }, 7000);

            $('.form-control, .form-select').on('focus', function() {
                $(this).parent().addClass('field-focused');
            }).on('blur', function() {
                $(this).parent().removeClass('field-focused');
            });
        });
    </script>
}