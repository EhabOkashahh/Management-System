@model CreateEmployeeDTO
@{
    ViewData["Title"] = "Edit Employee";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 mb-1">Edit Employee</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Employees">Employees</a></li>
                    <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@ViewData["Id"]">Details</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Edit</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Update Employee Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit"
                          enctype="multipart/form-data"
                          asp-route-id="@ViewData["Id"]"
                          id="editEmployeeForm">

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <strong>Please correct the following errors:</strong>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>

                        <partial name="PartialViews/_EmployeeFormsViews" />

                        <input asp-for="ImageName" hidden />

                        <div class="card bg-light border-0 mt-4 mb-4">
                            <div class="card-body">
                                <h6 class="text-muted mb-3">
                                    <i class="bi bi-clock-history me-2"></i>Update Information
                                </h6>
                                <div class="row g-3 small text-muted">
                                    <div class="col-md-6">
                                        <i class="bi bi-person me-1"></i>
                                        <strong>Last Updated By:</strong> System Admin
                                    </div>
                                    <div class="col-md-6">
                                        <i class="bi bi-calendar3 me-1"></i>
                                        <strong>Last Updated:</strong> @DateTime.Now.ToString("MMM dd, yyyy")
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 pt-3 border-top">
                            <button type="submit" class="btn btn-warning btn-lg text-dark" id="saveBtn">
                                <i class="bi bi-check-circle me-2"></i>Save Changes
                            </button>
                            <button type="reset" class="btn btn-outline-secondary btn-lg" id="resetBtn">
                                <i class="bi bi-arrow-counterclockwise me-2"></i>Reset Form
                            </button>
                            <a class="btn btn-outline-danger btn-lg ms-auto" asp-action="Index">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                        </div>

                        <div class="alert alert-info mt-3 d-flex align-items-start" role="alert">
                            <i class="bi bi-info-circle-fill me-2 mt-1"></i>
                            <div>
                                <small>
                                    <strong>Important:</strong> Changes will be applied immediately and may affect related records.
                                    Make sure all information is accurate before saving.
                                </small>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0">
                        <i class="bi bi-image me-2"></i>Current Photo
                    </h6>
                </div>
                <div class="card-body text-center">
                    <div class="current-photo-container mb-3">
                        <img id="currentPhoto"
                             src="~/Files/Images/@Model.ImageName"
                             alt="Employee Photo"
                             onerror="this.src='/images/default-avatar.png'">
                    </div>
                    <p class="text-muted small mb-0">
                        <i class="bi bi-info-circle me-1"></i>
                        Upload a new photo to replace the current one
                    </p>
                </div>
            </div>
        </div>
    </div>

<div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning">
                <h5 class="modal-title text-dark" id="confirmModalLabel">
                    <i class="bi bi-exclamation-triangle me-2"></i>Confirm Changes
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Are you sure you want to save these changes to the employee record?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning text-dark" id="confirmSave">
                    <i class="bi bi-check-circle me-1"></i>Confirm Save
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border-radius: 0.5rem;
    }

    .card-header {
        border-radius: 0.5rem 0.5rem 0 0 !important;
        padding: 1rem 1.25rem;
    }

    .current-photo-container {
        width: 200px;
        height: 200px;
        margin: 0 auto;
        border-radius: 50%;
        overflow: hidden;
        border: 4px solid #e9ecef;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .current-photo-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .timeline {
        position: relative;
        padding-left: 30px;
    }

        .timeline::before {
            content: '';
            position: absolute;
            left: 8px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #e9ecef;
        }

    .timeline-item {
        position: relative;
        margin-bottom: 1.5rem;
    }

        .timeline-item:last-child {
            margin-bottom: 0;
        }

    .timeline-marker {
        position: absolute;
        left: -26px;
        top: 5px;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        border: 3px solid #fff;
        box-shadow: 0 0 0 2px #e9ecef;
    }

    .timeline-content {
        padding-left: 10px;
    }

    .btn-lg {
        padding: 0.625rem 1.25rem;
        font-size: 1rem;
    }

    .gap-2 {
        gap: 0.5rem !important;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
    }

    .btn.loading {
        position: relative;
        color: transparent;
    }

        .btn.loading::after {
            content: "";
            position: absolute;
            width: 16px;
            height: 16px;
            top: 50%;
            left: 50%;
            margin-left: -8px;
            margin-top: -8px;
            border: 2px solid currentColor;
            border-radius: 50%;
            border-top-color: transparent;
            animation: spinner 0.6s linear infinite;
        }

    keyframes spinner {
        to

    {
        transform: rotate(360deg);
    }

    }

    .alert-info {
        background-color: #e7f3ff;
        border-color: #b3d9ff;
        color: #004085;
    }

    media (max-width: 992px) {
        .col-lg-4

    {
        margin-top: 1rem;
    }

    }

    media (max-width: 768px) {
        .d-flex.gap-2

    {
        flex-direction: column;
    }

    .d-flex.gap-2 .btn {
        width: 100%;
    }

    .d-flex.gap-2 .ms-auto {
        margin-left: 0 !important;
    }

    .current-photo-container {
        width: 150px;
        height: 150px;
    }

    }
</style>

@section ValidationSection {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#editEmployeeForm').on('submit', function(e) {
                if ($(this).valid()) {
                    const saveBtn = $('#saveBtn');
                    saveBtn.addClass('loading').prop('disabled', true);
                }
            });

            $('#resetBtn').on('click', function(e) {
                e.preventDefault();
                if (confirm('Are you sure you want to reset all changes? Any unsaved modifications will be lost.')) {
                    $('#editEmployeeForm')[0].reset();
                    $('#editEmployeeForm').validate().resetForm();
                    $('.form-control, .form-select').removeClass('is-valid is-invalid');

                    $('#currentPhoto').attr('src', '~/Files/Images/@Model.ImageName');
                }
            });

            $('input[type="file"]').on('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    const validTypes = ['image/jpeg', 'image/png', 'image/gif'];
                    if (!validTypes.includes(file.type)) {
                        alert('Please upload a valid image file (JPG, PNG, or GIF)');
                        $(this).val('');
                        return;
                    }

                    if (file.size > 5 * 1024 * 1024) {
                        alert('File size must be less than 5MB');
                        $(this).val('');
                        return;
                    }

                    const reader = new FileReader();
                    reader.onload = function(e) {
                        $('#currentPhoto').attr('src', e.target.result);
                    };
                    reader.readAsDataURL(file);
                }
            });

            let formChanged = false;
            $('#editEmployeeForm :input').not('[type="hidden"]').on('change', function() {
                formChanged = true;
            });

            $('a[href]').not('[href^="#"]').on('click', function(e) {
                if (formChanged) {
                    if (!confirm('You have unsaved changes. Are you sure you want to leave?')) {
                        e.preventDefault();
                    }
                }
            });

            $('#editEmployeeForm').on('submit', function() {
                formChanged = false;
            });

            $.validator.setDefaults({
                errorElement: 'span',
                errorClass: 'invalid-feedback',
                highlight: function(element) {
                    $(element).addClass('is-invalid').removeClass('is-valid');
                },
                unhighlight: function(element) {
                    $(element).removeClass('is-invalid').addClass('is-valid');
                }
            });

            setTimeout(function() {
                $('.alert-danger').fadeOut('slow');
            }, 7000);

            $('.form-control, .form-select').on('focus', function() {
                $(this).parent().addClass('field-focused');
            }).on('blur', function() {
                $(this).parent().removeClass('field-focused');
            });
        });
    </script>
}